# Copy to .env and adjust as needed (optional)

RACK_ENV=development
LOG_LEVEL=INFO
PORT=8080
APP_VERSION=dev

# Background scrape interval in seconds (default 3600)
# METRICS_SCRAPE_INTERVAL_SECONDS=3600

# Set to 1 to disable the background scraper (e.g. tests set RACK_ENV=test)
# METRICS_SCHEDULER_DISABLED=0

# Optional SQLite persistence for price history (survives restarts)
# Local dev via podman:run uses ./data bind-mounted to /data in the container.
# PRICE_HISTORY_DB_PATH=/data/asset_history.db
# PORTFOLIO_DB_PATH=/data/portfolio.db
# PRICE_HISTORY_RETENTION_DAYS=365
