# Copy to .env and adjust as needed (optional)

RACK_ENV=development
LOG_LEVEL=INFO
PORT=8080
APP_VERSION=dev

# Background scrape interval in seconds (default 3600)
# METRICS_SCRAPE_INTERVAL_SECONDS=3600

# Set to 1 to disable the background scraper (e.g. tests set RACK_ENV=test)
# METRICS_SCHEDULER_DISABLED=0
